{
  "name": "notion-bot-assistant",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-platform personal assistant bot (Telegram/Discord/WhatsApp) with isolated per-user Supabase storage.",
  "type": "module",
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "register:discord-commands": "tsx src/adapters/discord/registerCommands.ts",
    "set:telegram-webhook": "tsx src/adapters/telegram/setWebhook.ts",
    "docker:build": "docker build -t notion-bot-assistant .",
    "docker:run": "docker run --rm -p 10000:10000 --env-file .env notion-bot-assistant"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "chart.js": "^4.4.4",
    "chartjs-node-canvas": "^5.0.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "groq-sdk": "^1.3.0",
    "helmet": "^8.2.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "tweetnacl": "^1.0.3",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/node": "^20.14.15",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.9",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4",
    "vitest": "^4.1.9"
  }
}
