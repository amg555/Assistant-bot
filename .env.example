# ------------------------------------------------------------------
# NEVER commit a real .env file. This file only documents the shape.
# All values below are server-side only secrets. Nothing in this file
# is ever sent to Telegram/Discord/WhatsApp users or embedded in any
# client-facing payload.
# ------------------------------------------------------------------

NODE_ENV=production
PORT=10000

# Comma-separated list of origins allowed to call any browser-facing
# route (health/status page only — the bot webhooks are server-to-server
# and are authenticated by signature, not by CORS).
ALLOWED_ORIGINS=https://myapp.com

# --- Supabase (BaaS) -------------------------------------------------
# Service role key bypasses RLS -- used ONLY on this server, NEVER in
# any frontend bundle, NEVER logged.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-me
SUPABASE_STORAGE_BUCKET=user-attachments

# --- Internal cron dispatcher -----------------------------------------
# Supabase pg_cron/pg_net (or a fallback external pinger) calls
# POST /internal/cron/dispatch with this shared secret in the header
# X-Internal-Cron-Secret. Rotate this value periodically.
INTERNAL_CRON_SECRET=replace-me-32-plus-random-chars

# --- Telegram ----------------------------------------------------------
TELEGRAM_BOT_TOKEN=replace-me
# Random secret you choose; also set on Telegram via setWebhook secret_token.
TELEGRAM_WEBHOOK_SECRET=replace-me
PUBLIC_BASE_URL=https://your-render-service.onrender.com

# --- Discord -------------------------------------------------------------
DISCORD_APP_ID=replace-me
DISCORD_PUBLIC_KEY=replace-me
DISCORD_BOT_TOKEN=replace-me

# --- WhatsApp (Meta Cloud API) — scaffolded, off until you complete
# Meta Business verification. Leaving these blank disables the adapter
# safely (requests are rejected, never silently accepted).
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# --- Link codes ----------------------------------------------------------
LINK_CODE_TTL_MINUTES=10

# --- Groq (optional AI features — natural-language parsing + RAG note
# search). Leaving GROQ_API_KEY blank disables the AI layer entirely and
# safely; the bot falls back to the existing rule-based command parser.
# AI is ALSO gated per-account (accounts.ai_enabled, default false) — a
# user must run "ai on" even after you configure this key.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Max Groq calls allowed per account per hour — protects you from a
# runaway bill if one account is abused or scripted against.
GROQ_MAX_CALLS_PER_HOUR=30

# --- Notion (optional two-way sync) --------------------------------------
# Leaving NOTION_OAUTH_CLIENT_ID blank disables the whole feature safely
# (the "notion connect" command tells the user it's not configured,
# rather than half-working). Create a PUBLIC integration at
# https://www.notion.so/my-integrations to get these values; the redirect
# URI you register there MUST be exactly
# "${PUBLIC_BASE_URL}/oauth/notion/callback".
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
# Set this after creating a webhook subscription in Notion's integration
# dashboard pointed at "${PUBLIC_BASE_URL}/webhooks/notion" (see
# docs/notion-sync.md) — used to verify the X-Notion-Signature header.
NOTION_WEBHOOK_SECRET=
# 64 hex characters (32 bytes) — generate with: openssl rand -hex 32
# Used to encrypt Notion access tokens at rest with AES-256-GCM. This is
# a REVERSIBLE encryption key (unlike password hashing) because we must
# be able to use the token to call the Notion API on the user's behalf.
# Rotating this key invalidates every already-stored Notion connection
# (users would need to reconnect) — store it as securely as any other
# root secret.
NOTION_TOKEN_ENCRYPTION_KEY=
# How many Notion API calls we allow ourselves per second, ACROSS ALL
# ACCOUNTS combined. Notion enforces an average of 3 req/sec per
# integration token — we default conservatively under that shared
# ceiling since every connected workspace shares the same integration.
NOTION_MAX_REQUESTS_PER_SECOND=2

# --- Jina (optional real semantic search) --------------------------------
# Leaving JINA_API_KEY blank keeps "ask" and note search on the
# always-available Postgres full-text (keyword) search — nothing
# breaks, search quality just stays keyword-based rather than semantic.
# Get a free key at https://jina.ai/embeddings (free tier: 1M tokens,
# rate-limited). ALSO gated per-account by "ai on" — sending note
# content to Jina is exactly as privacy-sensitive as sending it to Groq.
#
# IMPORTANT LICENSE NOTE: Jina's free-tier embedding models are
# CC-BY-NC licensed (non-commercial use only) as of when this was
# written. Confirm current licensing at jina.ai before enabling this on
# anything but a personal, non-commercial deployment — see
# docs/ai-integration.md.
JINA_API_KEY=
JINA_EMBEDDING_MODEL=jina-embeddings-v3
# Must match the `vector(768)` dimension declared on notes.embedding in
# supabase/schema.sql — if you change this, update the schema column
# type to match (vector(N)) and re-embed existing notes.
JINA_EMBEDDING_DIMENSIONS=768
